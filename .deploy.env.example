# Plantilla para deploy.sh
# Copia este archivo a .deploy.env y completa con tus valores reales.
# .deploy.env está en .gitignore y NUNCA debe subirse al repo.
#
# Uso:
#   cp .deploy.env.example .deploy.env
#   nano .deploy.env
#   source .deploy.env
#   ./deploy.sh

# Datos del VPS (REQUERIDOS)
export VPS_HOST="tu.vps.ip.o.dominio"
export VPS_USER="usuario_ssh"
export VPS_PROJECT_DIR="/ruta/al/proyecto/en/vps"

# Compose file (opcional, default: compose.production.yaml)
# export COMPOSE_FILE="compose.production.yaml"

# Password SSH (opcional, NO RECOMENDADO)
# Mejor usa llave SSH: ssh-copy-id usuario@host
# Solo úsalo si no puedes configurar llave SSH:
# export SSHPASS="tu_password_ssh"
